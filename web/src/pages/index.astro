---
export const prerender = false;

import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import LeaderboardTable from "../components/LeaderboardTable.astro";
import StatsStrip from "../components/StatsStrip.astro";
import { getLeaderboardSummary, hasDatabaseBinding, listLeaderboard } from "../lib/db";
import type { LeaderboardSortDirection, LeaderboardSortKey } from "../lib/types";

const sortValue = Astro.url.searchParams.get("sort");
const directionValue = Astro.url.searchParams.get("dir");
const sortKey: LeaderboardSortKey =
  sortValue === "tokens" || sortValue === "sbai" || sortValue === "updatedAt"
    ? sortValue
    : "profanityCount";
const sortDirection: LeaderboardSortDirection = directionValue === "asc" ? "asc" : "desc";

const databaseReady = hasDatabaseBinding();
const entries = databaseReady ? await listLeaderboard(50, sortKey, sortDirection) : [];
const summary = databaseReady
  ? await getLeaderboardSummary()
  : {
      participants: 0,
      totalEvents: 0,
      totalTokens: 0,
      averageSbai: 0,
    };

const stats = [
  { label: "Participants", value: summary.participants.toLocaleString("en-US"), tone: "red" as const },
  { label: "Average SBAI", value: summary.averageSbai.toFixed(3), tone: "teal" as const },
  { label: "Uploaded Tokens", value: summary.totalTokens.toLocaleString("en-US"), tone: "gold" as const },
];
---

<BaseLayout title="maleme leaderboard" description="maleme leaderboard">
  <main class="shell">
    <header class="topbar">
      <div class="brand">
        <div class="brand-mark">M</div>
        <div class="brand-copy">
          <div class="brand-title">maleme leaderboard</div>
        </div>
      </div>
      <a class="repo-link" href="https://github.com/Yeuoly/maleme" target="_blank" rel="noreferrer">
        <Image
          src="https://github.githubassets.com/images/modules/logos_page/GitHub-Mark.png"
          alt="GitHub"
          class="repo-avatar"
          width={42}
          height={42}
        />
      </a>
    </header>

    <section class="intro">
      <StatsStrip items={stats} />
    </section>

    <LeaderboardTable entries={entries} sortKey={sortKey} sortDirection={sortDirection} />
  </main>
</BaseLayout>

<style>
  .intro {
    margin-bottom: 18px;
    display: block;
  }

  .repo-link {
    width: 42px;
    height: 42px;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--border);
    box-shadow: var(--shadow);
  }

  .repo-avatar {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 980px) {
    .intro {
      margin-bottom: 16px;
    }
  }
</style>
