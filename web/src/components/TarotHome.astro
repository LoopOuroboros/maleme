---
import type { CollectionEntry } from "astro:content";
import SiteHeader from "./SiteHeader.astro";
import { getI18n, type Locale } from "../lib/i18n";

type Props = {
  cards: CollectionEntry<"tarot">[];
  locale: Locale;
};

const { locale } = Astro.props;
const t = getI18n(locale);
const cards = [...Astro.props.cards].sort((left, right) => left.data.order - right.data.order);
const initialCard = cards[0];
const cardsJson = JSON.stringify(
  cards.map((card) => ({
    slug: card.id,
    code: card.data.code,
    title: card.data.title,
    summary: card.data.summary,
    omen: card.data.omen,
  })),
).replaceAll("</", "<\\/");
---

<main class="tarot-shell">
  <div class="shell">
    <SiteHeader
      active="tarot"
      title={t.tarot.brandTitle}
      subtitle={t.tarot.brandSubtitle}
      locale={locale}
    />

    <section class="stage surface">
      <div class="stage-copy">
        <div class="hero-kicker">{t.tarot.kicker}</div>
        <h1 class="hero-title">{t.tarot.heroTitle}</h1>
        <p class="hero-copy">{t.tarot.heroCopy}</p>
      </div>

      <div class="draw-experience">
        <button type="button" class="draw-card" id="draw-button" aria-label={t.tarot.drawButton}>
          <span class="draw-card-inner">
            <span class="draw-card-code">M</span>
            <span class="draw-card-title">{t.tarot.cardFaceLabel}</span>
            <span class="draw-card-hint">{t.tarot.cardFaceHint}</span>
          </span>
        </button>

        <div class="draw-result-shell" id="draw-result-shell">
          <div class="draw-result-label">{t.tarot.resultLabel}</div>
          <a class="draw-result" id="draw-result" href={`/cards/${initialCard.id}`}>
            <span class="draw-result-code">{initialCard.data.code}</span>
            <span class="draw-result-title">{initialCard.data.title}</span>
            <span class="draw-result-omen">{initialCard.data.omen}</span>
          </a>
          <div class="draw-actions">
            <a class="open-card" id="open-card" href={`/cards/${initialCard.id}`}>{t.tarot.openCard}</a>
            <button type="button" class="draw-again" id="draw-again">{t.tarot.drawAgain}</button>
          </div>
        </div>
      </div>
    </section>
  </div>
</main>

<script define:vars={{ cardsJson }}>
  const cards = JSON.parse(cardsJson);
  const drawButton = document.getElementById("draw-button");
  const drawAgainButton = document.getElementById("draw-again");
  const drawResultShell = document.getElementById("draw-result-shell");
  const drawResult = document.getElementById("draw-result");
  const openCard = document.getElementById("open-card");

  function paint(card) {
    drawResult.href = `/cards/${card.slug}`;
    openCard.href = `/cards/${card.slug}`;
    drawResult.querySelector(".draw-result-code").textContent = card.code;
    drawResult.querySelector(".draw-result-title").textContent = card.title;
    drawResult.querySelector(".draw-result-omen").textContent = card.omen;
    drawResultShell.classList.add("is-visible");
  }

  function draw() {
    drawButton.classList.remove("is-shuffling");
    void drawButton.offsetWidth;
    drawButton.classList.add("is-shuffling");
    const card = cards[Math.floor(Math.random() * cards.length)];
    window.setTimeout(() => {
      paint(card);
    }, 220);
  }

  drawButton.addEventListener("click", draw);
  drawAgainButton.addEventListener("click", draw);
</script>

<style>
  .tarot-shell {
    min-height: 100vh;
  }

  .stage {
    min-height: calc(100vh - 108px);
    padding: 28px;
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(320px, 0.78fr);
    gap: 28px;
    align-items: center;
    background:
      radial-gradient(circle at top left, rgba(255, 183, 3, 0.18), transparent 28%),
      radial-gradient(circle at top right, rgba(255, 91, 97, 0.16), transparent 26%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.94), rgba(250, 252, 255, 0.88));
    overflow: hidden;
  }

  .stage-copy {
    display: grid;
    gap: 14px;
    align-content: center;
  }

  .hero-kicker {
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .hero-title {
    margin: 0;
    font-size: clamp(42px, 6vw, 88px);
    line-height: 0.98;
    max-width: 8ch;
  }

  .hero-copy {
    margin: 0;
    max-width: 34rem;
    font-size: clamp(16px, 2vw, 20px);
    line-height: 1.7;
    color: var(--muted);
  }

  .draw-experience {
    display: grid;
    justify-items: center;
    gap: 18px;
  }

  .draw-card {
    position: relative;
    width: min(100%, 360px);
    aspect-ratio: 0.72;
    padding: 0;
    border: 0;
    background: none;
    cursor: pointer;
  }

  .draw-card::before,
  .draw-card::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 8px;
    border: 1px solid rgba(255, 91, 97, 0.18);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(246, 248, 255, 0.86));
    box-shadow: 0 30px 70px rgba(19, 32, 51, 0.14);
    transform-origin: center;
  }

  .draw-card::before {
    transform: translate(-14px, 12px) rotate(-6deg);
  }

  .draw-card::after {
    transform: translate(14px, 12px) rotate(7deg);
  }

  .draw-card-inner {
    position: absolute;
    inset: 0;
    z-index: 1;
    display: grid;
    place-items: center;
    gap: 12px;
    padding: 24px;
    border-radius: 8px;
    border: 1px solid rgba(255, 91, 97, 0.24);
    background:
      radial-gradient(circle at 50% 18%, rgba(255, 183, 3, 0.18), transparent 22%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(249, 251, 255, 0.9));
    box-shadow: 0 34px 80px rgba(19, 32, 51, 0.16);
  }

  .draw-card.is-shuffling .draw-card-inner {
    animation: shuffle 460ms ease;
  }

  .draw-card-code {
    width: 88px;
    height: 88px;
    border-radius: 8px;
    display: grid;
    place-items: center;
    background: linear-gradient(135deg, rgba(255, 91, 97, 0.14), rgba(255, 183, 3, 0.18));
    color: var(--accent);
    font-size: 42px;
    font-weight: 900;
  }

  .draw-card-title {
    font-size: clamp(24px, 3vw, 34px);
    line-height: 1;
    font-weight: 900;
    text-align: center;
  }

  .draw-card-hint {
    text-align: center;
    color: var(--muted);
    line-height: 1.6;
    max-width: 16rem;
  }

  .draw-result-shell {
    width: min(100%, 360px);
    display: grid;
    gap: 10px;
    opacity: 0;
    transform: translateY(12px);
    pointer-events: none;
    transition: opacity 220ms ease, transform 220ms ease;
  }

  .draw-result-shell.is-visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .draw-result-label {
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    text-align: center;
  }

  .draw-result {
    display: grid;
    gap: 8px;
    padding: 18px;
    border-radius: 8px;
    border: 1px solid rgba(255, 91, 97, 0.22);
    background: rgba(255, 255, 255, 0.84);
    box-shadow: 0 20px 40px rgba(19, 32, 51, 0.08);
    text-decoration: none;
  }

  .draw-result-code {
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .draw-result-title {
    font-size: clamp(24px, 3vw, 32px);
    line-height: 1;
    font-weight: 900;
  }

  .draw-result-omen {
    color: var(--muted);
    line-height: 1.65;
  }

  .draw-actions {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
  }

  .open-card,
  .draw-again {
    min-height: 46px;
    border-radius: 8px;
    padding: 0 16px;
    font: inherit;
    font-size: 14px;
    font-weight: 900;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
  }

  .open-card {
    border: 0;
    color: #ffffff;
    background: linear-gradient(135deg, #d62839, #ff5b61);
    box-shadow: 0 16px 28px rgba(214, 40, 57, 0.22);
  }

  .draw-again {
    border: 1px solid var(--border);
    color: var(--text);
    background: rgba(255, 255, 255, 0.78);
    cursor: pointer;
  }

  @keyframes shuffle {
    0% {
      transform: translateX(0) rotate(0deg);
    }
    30% {
      transform: translateX(-12px) rotate(-4deg);
    }
    60% {
      transform: translateX(10px) rotate(4deg);
    }
    100% {
      transform: translateX(0) rotate(0deg);
    }
  }

  @media (max-width: 980px) {
    .stage {
      min-height: auto;
      grid-template-columns: 1fr;
      padding: 22px;
    }

    .stage-copy {
      justify-items: center;
      text-align: center;
    }

    .hero-title {
      max-width: none;
      font-size: clamp(34px, 10vw, 58px);
    }
  }
</style>
