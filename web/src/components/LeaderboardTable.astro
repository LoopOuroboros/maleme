---
import { Image } from "astro:assets";
import type { LeaderboardEntry } from "../lib/types";
import { buildShareButtonText, getSharePath } from "../lib/share";

type Props = {
  entries: LeaderboardEntry[];
};

const { entries } = Astro.props;
---

<section class="surface leaderboard">
  <div class="leaderboard-header">
    <h2 class="section-title">Leaderboard</h2>
  </div>

  <div class="table-shell">
    <table>
      <thead>
        <tr>
          <th>Rank</th>
          <th>Account</th>
          <th>Events</th>
          <th>Tokens</th>
          <th>SBAI</th>
          <th>Updated</th>
          <th>Share</th>
        </tr>
      </thead>
      <tbody>
        {
          entries.map((entry) => {
            const profileHref = `/u/${encodeURIComponent(entry.login)}`;
            const shareHref = getSharePath(entry.githubId);
            const shareText = buildShareButtonText(entry);

            return (
              <tr class="leaderboard-row" data-profile-link={profileHref} tabindex="0" role="link">
                <td class="rank">#{entry.rank}</td>
                <td>
                  <a href={profileHref} class="term-cell">
                    <Image
                      src={entry.avatarUrl}
                      alt={entry.displayName}
                      class="term-image"
                      width={36}
                      height={36}
                    />
                    <span>
                      <span class="term-text">{entry.displayName}</span>
                      <span class="term-subtext">@{entry.login}</span>
                    </span>
                  </a>
                </td>
                <td>{entry.profanityCount.toLocaleString("en-US")}</td>
                <td>{entry.tokens.toLocaleString("en-US")}</td>
                <td class="change">{entry.sbai.toFixed(1)}</td>
                <td>{new Date(entry.updatedAt).toLocaleDateString("en-US")}</td>
                <td class="share-cell">
                  <button
                    type="button"
                    class="share-button"
                    data-share-url={shareHref}
                    data-share-title={`${entry.displayName} 的 maleme 分享卡`}
                    data-share-text={shareText}
                    aria-label={`分享 ${entry.displayName} 的 leaderboard 数据`}
                  >
                    分享
                  </button>
                </td>
              </tr>
            );
          })
        }
      </tbody>
    </table>
  </div>
</section>

<script>
  for (const row of document.querySelectorAll(".leaderboard-row")) {
    const navigate = () => {
      const href = row.getAttribute("data-profile-link");
      if (href) {
        window.location.href = href;
      }
    };

    row.addEventListener("click", (event) => {
      const target = event.target;
      if (target instanceof HTMLElement && target.closest("a, button, input, textarea, select")) {
        return;
      }

      navigate();
    });

    row.addEventListener("keydown", (event) => {
      if (event.key !== "Enter" && event.key !== " ") {
        return;
      }

      event.preventDefault();
      navigate();
    });
  }

  for (const button of document.querySelectorAll(".share-button")) {
    button.addEventListener("click", async (event) => {
      event.preventDefault();
      event.stopPropagation();

      const shareUrl = button.getAttribute("data-share-url");
      const shareTitle = button.getAttribute("data-share-title") || "maleme leaderboard";
      const shareText = button.getAttribute("data-share-text") || shareTitle;

      if (!shareUrl) {
        return;
      }

      const absoluteUrl = new URL(shareUrl, window.location.origin).toString();

      try {
        if (navigator.share) {
          await navigator.share({
            title: shareTitle,
            text: shareText,
            url: absoluteUrl,
          });
          return;
        }

        if (navigator.clipboard?.writeText) {
          await navigator.clipboard.writeText(absoluteUrl);
          button.textContent = "已复制";
          window.setTimeout(() => {
            button.textContent = "分享";
          }, 1800);
          return;
        }
      } catch (error) {
        if (error instanceof DOMException && error.name === "AbortError") {
          return;
        }
      }

      window.open(absoluteUrl, "_blank", "noopener,noreferrer");
    });
  }
</script>

<style>
  .leaderboard {
    padding: 18px;
  }

  .leaderboard-header {
    margin-bottom: 14px;
  }

  .table-shell {
    overflow: auto;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.72);
  }

  table {
    width: 100%;
    border-collapse: collapse;
  }

  th,
  td {
    text-align: left;
    padding: 14px 12px;
    border-bottom: 1px solid var(--border);
    font-size: 14px;
    vertical-align: middle;
  }

  th {
    font-size: 12px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--muted);
    background: rgba(246, 248, 251, 0.92);
    position: sticky;
    top: 0;
  }

  tbody tr:last-child td {
    border-bottom: none;
  }

  .leaderboard-row {
    cursor: pointer;
    transition: background-color 160ms ease;
  }

  .leaderboard-row:hover td,
  .leaderboard-row:focus-visible td {
    background: rgba(15, 163, 177, 0.08);
  }

  .rank {
    font-weight: 900;
    color: var(--accent);
  }

  .term-cell {
    display: flex;
    align-items: center;
    gap: 10px;
    color: inherit;
    text-decoration: none;
  }

  .term-image {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    object-fit: cover;
    flex: 0 0 auto;
  }

  .term-text {
    display: block;
    font-weight: 800;
  }

  .term-subtext {
    display: block;
    color: var(--muted);
    font-size: 12px;
    margin-top: 3px;
  }

  .change {
    color: #0d7a84;
    font-weight: 800;
  }

  .share-cell {
    width: 88px;
  }

  .share-button {
    min-height: 34px;
    padding: 0 12px;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.9);
    color: var(--text);
    font: inherit;
    font-weight: 700;
    cursor: pointer;
    transition:
      border-color 160ms ease,
      background-color 160ms ease,
      color 160ms ease;
  }

  .share-button:hover,
  .share-button:focus-visible {
    border-color: rgba(15, 163, 177, 0.45);
    background: rgba(15, 163, 177, 0.12);
    color: #0d7a84;
  }
</style>
