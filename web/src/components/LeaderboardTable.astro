---
import type {
  LeaderboardEntry,
  LeaderboardSortDirection,
  LeaderboardSortKey,
} from "../lib/types";

type Props = {
  entries: LeaderboardEntry[];
  sortKey: LeaderboardSortKey;
  sortDirection: LeaderboardSortDirection;
};

const { entries, sortKey, sortDirection } = Astro.props;

const sortLabels: Record<LeaderboardSortKey, string> = {
  profanityCount: "Times Cursed",
  tokens: "Tokens",
  sbai: "SBAI",
  updatedAt: "Updated",
};

const sortKeys: LeaderboardSortKey[] = ["profanityCount", "tokens", "sbai", "updatedAt"];
const directionItems: LeaderboardSortDirection[] = ["desc", "asc"];

function hrefFor(nextSortKey: LeaderboardSortKey, nextDirection: LeaderboardSortDirection) {
  const search = new URLSearchParams({
    sort: nextSortKey,
    dir: nextDirection,
  });
  return `/?${search.toString()}`;
}
---

<section class="surface leaderboard">
  <div class="leaderboard-header">
    <h2 class="section-title">Leaderboard</h2>
    <div class="leaderboard-tools">
      <div class="tool-group">
        {
          sortKeys.map((item) => (
            <a
              href={hrefFor(item, sortDirection)}
              class:list={["tool-chip", sortKey === item && "is-active"]}
            >
              {sortLabels[item]}
            </a>
          ))
        }
      </div>
      <div class="tool-group">
        {
          directionItems.map((item) => (
            <a
              href={hrefFor(sortKey, item)}
              class:list={["tool-chip", sortDirection === item && "is-active"]}
            >
              {item === "desc" ? "Descending" : "Ascending"}
            </a>
          ))
        }
      </div>
    </div>
  </div>

  <div class="table-shell">
    <table>
      <thead>
        <tr>
          <th>Rank</th>
          <th>Account</th>
          <th>Times Cursed</th>
          <th>Tokens</th>
          <th>SBAI</th>
          <th>Updated</th>
        </tr>
      </thead>
      <tbody>
        {
          entries.map((entry) => (
            <tr>
              <td class="rank">#{entry.rank}</td>
              <td class="term-cell">
                <img src={entry.avatarUrl} alt={entry.displayName} class="term-image" />
                <span>
                  <span class="term-text">{entry.displayName}</span>
                  <span class="term-subtext">@{entry.login}</span>
                </span>
              </td>
              <td>{entry.profanityCount.toLocaleString("en-US")}</td>
              <td>{entry.tokens.toLocaleString("en-US")}</td>
              <td class="change">{entry.sbai.toFixed(3)}</td>
              <td>{new Date(entry.updatedAt).toLocaleDateString("en-US")}</td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>
</section>

<style>
  .leaderboard {
    padding: 18px;
  }

  .leaderboard-header {
    margin-bottom: 14px;
    display: flex;
    justify-content: space-between;
    gap: 14px;
    align-items: flex-start;
    flex-wrap: wrap;
  }

  .leaderboard-tools {
    display: flex;
    gap: 10px;
    align-items: center;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .tool-group {
    display: inline-flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .tool-chip {
    text-decoration: none;
    color: var(--muted);
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.02em;
    border: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.76);
    padding: 8px 10px;
    border-radius: 8px;
    transition: border-color 140ms ease, color 140ms ease, background 140ms ease;
  }

  .tool-chip.is-active {
    color: var(--accent);
    border-color: rgba(255, 91, 97, 0.34);
    background: rgba(255, 91, 97, 0.1);
  }

  .table-shell {
    overflow: auto;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.72);
  }

  table {
    width: 100%;
    border-collapse: collapse;
  }

  th,
  td {
    text-align: left;
    padding: 14px 12px;
    border-bottom: 1px solid var(--border);
    font-size: 14px;
    vertical-align: middle;
  }

  th {
    font-size: 12px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--muted);
    background: rgba(246, 248, 251, 0.92);
    position: sticky;
    top: 0;
  }

  tbody tr:last-child td {
    border-bottom: none;
  }

  .rank {
    font-weight: 900;
    color: var(--accent);
  }

  .term-cell {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .term-image {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    object-fit: cover;
    flex: 0 0 auto;
  }

  .term-text {
    display: block;
    font-weight: 800;
  }

  .term-subtext {
    display: block;
    color: var(--muted);
    font-size: 12px;
    margin-top: 3px;
  }

  .change {
    color: #0d7a84;
    font-weight: 800;
  }

  @media (max-width: 980px) {
    .leaderboard-header {
      flex-direction: column;
    }

    .leaderboard-tools {
      justify-content: flex-start;
    }
  }
</style>
